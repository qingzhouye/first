<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg"
        android:paddingTop="@dimen/safe_area_top">

        <!-- 头部信息 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/gradient_primary"
            android:padding="@dimen/spacing_xl"
            android:layout_marginBottom="@dimen/spacing_lg">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_xxl"
                android:textStyle="bold"
                android:textColor="@color/text_white" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/semi_transparent_white" />
        </LinearLayout>

        <!-- 贷款信息卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="@dimen/card_padding"
            android:layout_marginBottom="@dimen/spacing_lg">

            <!-- 基本信息组 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="基本信息"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_md" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="贷款本金"
                        android:textSize="@dimen/text_xs"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvPrincipal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="@dimen/spacing_xs" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="年利率"
                        android:textSize="@dimen/text_xs"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="@dimen/spacing_xs" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="贷款期限"
                        android:textSize="@dimen/text_xs"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvMonths"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="@dimen/spacing_xs" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="开始日期"
                        android:textSize="@dimen/text_xs"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvStartDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="@dimen/spacing_xs" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="@dimen/spacing_md" />

            <!-- 还款信息组 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="还款情况"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_md" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="已还金额"
                        android:textSize="@dimen/text_xs"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvTotalPaid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="@dimen/spacing_xs" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="剩余本金"
                        android:textSize="@dimen/text_xs"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvRemaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginTop="@dimen/spacing_xs" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="当前月供"
                        android:textSize="@dimen/text_xs"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvMonthlyPayment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginTop="@dimen/spacing_xs" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="还款进度"
                        android:textSize="@dimen/text_xs"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="@dimen/spacing_xs" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 进度条 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background_alt"
            android:padding="@dimen/card_padding"
            android:layout_marginBottom="@dimen/spacing_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="还款进度"
                android:textSize="@dimen/text_md"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="@dimen/spacing_md" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="已还"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_secondary" />

                <ProgressBar
                    android:id="@+id/progressPaid"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="20dp"
                    android:layout_weight="1"
                    android:progressDrawable="@drawable/gradient_success" />

                <TextView
                    android:id="@+id/tvProgressPercent"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_primary"
                    android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="剩余"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_secondary" />

                <ProgressBar
                    android:id="@+id/progressRemaining"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="20dp"
                    android:layout_weight="1"
                    android:progressDrawable="@drawable/gradient_danger" />

                <TextView
                    android:id="@+id/tvRemainingPercent"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_primary"
                    android:gravity="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnViewSchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/view_schedule"
                style="@style/SecondaryButton" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnMakePayment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/make_payment"
                    style="@style/SuccessButton" />

                <Button
                    android:id="@+id/btnDelete"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/delete_loan"
                    style="@style/DangerButton" />
            </LinearLayout>
        </LinearLayout>

        <!-- 还款输入框 -->
        <LinearLayout
            android:id="@+id/layoutPayment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background_alt"
            android:padding="16dp"
            android:layout_marginTop="@dimen/spacing_lg"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/InputStyle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPaymentAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/payment_amount"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnConfirmPayment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/confirm_payment"
                style="@style/SuccessButton" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
